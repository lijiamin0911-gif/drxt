# ==========================================
# 订单协同系统 - 多数据库环境配置模板 (.env)
# ==========================================

# ----------------------------
# 数据库选择
# ----------------------------
# 是否使用 Supabase 数据库。
# - 设置为 true 则通过方式A (SUPABASE_URL + SUPABASE_KEY) 连接 Supabase。
# - 设置为 false/不设置 则使用方式B (Tencent Cloud / 标准 PostgreSQL) 连接。
USE_SUPABASE=false

# ----------------------------
# 方式A: Supabase 数据库连接配置 (当 USE_SUPABASE=true 时使用)
# ----------------------------
# Supabase 的 API 访问 URL 域名
SUPABASE_URL=https://your-project-ref.supabase.co
# Supabase 的 Service Role Key 或 Anon Key (推荐使用 Service Role Key 以获得最高权限)
SUPABASE_KEY=your-supabase-service-role-or-anon-key

# ----------------------------
# 方式B: 腾讯云 / 阿里云 / 标准 PostgreSQL 配置 (当 USE_SUPABASE=false 或不指定时使用)
# ----------------------------
# 数据库服务器主机地址 (IP 或域名)
DB_HOST=your-tencent-cloud-postgresql-host.com
# 数据库服务器端口 (默认 5432)
DB_PORT=5432
# 数据库登录用户名
DB_USER=postgres
# 数据库登录密码
DB_PASSWORD=your-secure-database-password
# 数据库名称
DB_NAME=erp_system
# 是否对数据库连接启用 SSL 安全验证。部分云平台 (例如 Supabase, Render) 必须设为 true；本地开发调试可设为 false。
DB_SSL=true

# ----------------------------
# 其他系统配置 (保留可选)
# ----------------------------
# GEMINI_API_KEY=your-gemini-api-key-if-used
